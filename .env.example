# Qwen Cloud (Alibaba Cloud Model Studio, OpenAI-compatible endpoint)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Model IDs — verify against the Qwen Cloud console; never hardcode elsewhere.
MODEL_REASONING=qwen-max
MODEL_FAST=qwen-turbo
MODEL_VISION=qwen-vl-max
MODEL_EMBED=text-embedding-v3

# Postgres
POSTGRES_USER=memora
POSTGRES_PASSWORD=memora
POSTGRES_DB=memora
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://memora:memora@postgres:5432/memora

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Memory defaults
RECALL_BUDGET_TOKENS=1500
CONSOLIDATION_EVERY_N_EVENTS=15
DECAY_TICK_INTERVAL_SECONDS=3600

# Gift-clarification anomaly detection (packages/mcp-memory)
ANOMALY_SIMILARITY_THRESHOLD=0.55
ANOMALY_MIN_PURCHASE_HISTORY=3
